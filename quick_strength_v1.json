                      "tempo": null,
                      "notes": "Elbows track inside knees. Pause 1 second at the bottom. Stay upright.",
                      "priority": "primary",
                      "orderIndex": 0,
                      "restSeconds": 15,
                      "alternatives": []
                    },
                    {
                      "exerciseId": "one_arm_dumbbell_row",

    {
      "id": "quick_strength",
      "name": "Quick Strength",
      "version": "1.0.1",
      "description": "Full-body home gym training for limited time. Three interchangeable sessions each cover every major movement pattern in 20\u201330 minutes via compound supersets. Built on minimum-effective-dose research: 2\u20133 hard sets per muscle group at RPE 8\u20139, taken close to failure, is sufficient to maintain and build strength at 1\u20133 sessions per week (Bickel 2011; Ralston 2017; Schoenfeld 2019). Agonist-antagonist supersets cut session time by ~40% with no loss in performance (Kelleher 2010). Pull:push ratio is 2:1 to support climbing shoulder health.",
      "tags": [
        "home",
        "dumbbell",
        "time-efficient",
        "full-body",
        "minimum-effective-dose"
      ],
      "targetProfile": "intermediate",
      "createdAt": "2026-06-11",
      "sourceUrl": null,
      "releaseNotes": null,
      "plans": [
        {
          "id": "qs_3day",
          "name": "3-Day Rotation",
          "scheduleDescription": "Any 1\u20133 days/week \u2014 each session stands alone",
          "daysPerWeek": 3,
          "orderIndex": 0,
          "goal": "Maintain and build full-body strength with minimal time. Each session hits every major pattern: hinge, squat, push, pull. Lift heavy \u2014 compounds should feel challenging by rep 4\u20135 (RPE 8\u20139). Two sessions per week produces gradual progress; one session per week preserves what you have. Do the days in any order, skip freely \u2014 they're designed to be independent.",
          "workouts": [
            {
